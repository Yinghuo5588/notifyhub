# NotifyHub 配置文件
# 复制此文件为 .env 并修改

# 安全密钥（必须修改！用于JWT加密）
SECRET_KEY=please-change-this-to-a-random-string

# 管理员初始账号
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# 服务配置
HOST=0.0.0.0
PORT=9800
DEBUG=false

# 数据库路径
DATABASE_URL=sqlite+aiosqlite:///./data/notifyhub.db

# JWT过期时间（小时）
JWT_EXPIRE_HOURS=72

# 历史记录保留天数
LOG_RETENTION_DAYS=30